---
// Servicios.astro
---

<section
  id="servicios"
  class="py-24 md:py-36 relative overflow-hidden"
  style="background: linear-gradient(160deg, #1C3A1C 0%, #2f5030 60%, #3a6339 100%);"
>
  <!-- Decorative leaves -->
  <div class="absolute top-0 right-0 w-72 h-72 opacity-10 pointer-events-none">
    <svg viewBox="0 0 300 300" fill="none">
      <path d="M250 20C320 80 340 180 260 260 200 320 80 340 20 260 -20 200 60 120 120 80 180 40 200 20 250 20Z" fill="#6e9a6d"/>
    </svg>
  </div>

  <div class="max-w-6xl mx-auto px-6 md:px-12">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-cream font-body text-sm tracking-[0.3em] uppercase mb-4 flex items-center justify-center gap-3">
        <span class="w-6 h-px bg-cream inline-block"></span>
        Lo que ofrezco
        <span class="w-6 h-px bg-cream inline-block"></span>
      </p>
      <h2
        class="font-display text-cream leading-tight"
        style="font-family:'Cormorant Garamond',serif; font-size:clamp(2.2rem,4vw,3.5rem);"
      >
        Servicios &amp; <em style="color:#cda97f;">Modalidades</em>
      </h2>
    </div>

    <!-- Top row: 4-column glass card strip (matching design) -->
    <div class="glass-card rounded-2xl p-6 md:p-8 mb-8 grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x divide-sage-600/30">
      {[
        {
          icon: `<svg class="w-10 h-10" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="16"/><circle cx="20" cy="20" r="8"/><path d="M20 4v4M20 32v4M4 20h4M32 20h4"/></svg>`,
          title: 'Sesión Individual',
          desc: 'Un espacio íntimo para trabajar tus bloqueos emocionales, patrones limitantes y el análisis de tu historia personal.',
        },
        {
          icon: `<svg class="w-10 h-10" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="8" y="6" width="24" height="20" rx="2"/><path d="M14 26v6M26 26v6M10 32h20"/><path d="M16 14h8M20 11v6"/></svg>`,
          title: 'Constelaciones Familiares',
          desc: 'Método vivencial para revelar y sanar los vínculos sistémicos y patrones transgeneracionales de tu linaje.',
        },
        {
          icon: `<svg class="w-10 h-10" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="20" r="5"/><circle cx="28" cy="20" r="5"/><path d="M17 20h6"/><path d="M7 14C5 10 8 4 14 6M21 34c2 4 9 4 9-2"/></svg>`,
          title: 'Coaching de Vida',
          desc: 'Acompañamiento para definir metas claras, superar obstáculos y alcanzar el bienestar integral que buscás.',
        },
        {
          icon: `<svg class="w-10 h-10" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="20" cy="20" r="10"/><path d="M20 10V20L26 26"/><path d="M10 20H4M36 20h-6M20 4v6M20 30v6"/></svg>`,
          title: 'Sesión Online',
          desc: 'Atención a distancia para personas en cualquier parte del mundo, con la misma profundidad y calidez.',
        },
      ].map(({ icon, title, desc }) => (
        <div class="service-card flex flex-col items-center text-center px-4 py-2 md:py-0 cursor-default">
          <div class="w-16 h-16 rounded-full bg-sage-600/20 border border-sage-400/20 flex items-center justify-center text-cream mb-4" set:html={icon} />
          <h3 class="font-display text-cream text-lg mb-2" style="font-family:'Cormorant Garamond',serif;">{title}</h3>
          <p class="text-cream/55 text-xs font-body leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>

    <!-- Bottom row: 3 Earth-tone specialty cards + 1 photo card (matching design) -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <!-- Specialty card 1 – Sage green -->
      <div class="service-card rounded-2xl p-6 flex flex-col items-center text-center col-span-1" style="background: rgba(77,125,76,0.85);">
        <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-cream" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </div>
        <h3 class="font-display text-cream text-base mb-2" style="font-family:'Cormorant Garamond',serif;">Presencial – Virreyes</h3>
        <p class="text-cream/60 text-xs font-body">Pedro Díaz 2041, Virreyes, Buenos Aires</p>
      </div>

      <!-- Specialty card 2 – Earth brown -->
      <div class="service-card rounded-2xl p-6 flex flex-col items-center text-center col-span-1" style="background: rgba(95,58,38,0.9);">
        <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-earth-light" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-cream text-base mb-2" style="font-family:'Cormorant Garamond',serif;">Jornadas Holísticas</h3>
        <p class="text-cream/60 text-xs font-body">Pedro Ballester 2458, Garín, Bs.As.</p>
      </div>

      <!-- Specialty card 3 – Warm earth -->
      <div class="service-card rounded-2xl p-6 flex flex-col items-center text-center col-span-1" style="background: rgba(143,90,52,0.85);">
        <div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-cream" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-cream text-base mb-2" style="font-family:'Cormorant Garamond',serif;">Aromaterapia</h3>
        <p class="text-cream/60 text-xs font-body">Home Sprays Energía &amp; Armonía, complemento terapéutico</p>
      </div>

      <!-- Photo/CTA card -->
      <div
        class="service-card rounded-2xl overflow-hidden col-span-1 relative flex flex-col justify-end p-5 min-h-[180px]"
        style="background: linear-gradient(135deg, #2f5030, #1C3A1C);"
      >
        <!-- Background leaf icon -->
        <div class="absolute inset-0 flex items-center justify-center opacity-10">
          <svg class="w-32 h-32" viewBox="0 0 100 120" fill="white">
            <path d="M50 5C70 5 90 25 85 55 80 80 60 110 50 115 40 110 20 80 15 55 10 25 30 5 50 5Z"/>
          </svg>
        </div>
        <div class="relative z-10">
          <p class="font-display text-cream text-sm mb-1" style="font-family:'Cormorant Garamond',serif;">¿Primera vez?</p>
          <p class="text-cream/60 text-xs font-body mb-3">Consultá sin compromiso</p>
          <a
            href="https://wa.me/5491132585949"
            target="_blank"
            class="inline-block bg-earth-light/90 hover:bg-earth-light text-forest text-xs font-body font-semibold px-4 py-2 rounded-full transition-colors"
          >
            Escribime →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Top wave -->
  <div class="absolute top-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 0 C360 60, 1080 60, 1440 0 L1440 0 L0 0Z" fill="#F5F0E8"/>
    </svg>
  </div>

  <!-- Bottom wave -->
  <div class="absolute bottom-0 left-0 right-0 pointer-events-none">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 60 C360 0, 1080 0, 1440 60 L1440 60 L0 60Z" fill="#F5F0E8"/>
    </svg>
  </div>
</section>
