---
// Footer.astro
---

<footer class="bg-forest py-12 px-6 md:px-12 border-t border-sage-800/40">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <p
          class="font-display text-2xl text-cream mb-1"
          style="font-family:'Cormorant Garamond',serif;"
        >
          Raul Lencinas
        </p>
        <p class="text-sage-400 text-xs font-body tracking-widest uppercase mb-4">Terapias Integrativas</p>
        <p class="text-cream/50 text-sm font-body leading-relaxed max-w-xs">
          Coach Life · Terapeuta Emocional · Constelador Familiar · Master en Psicogénesis Transgeneracional
        </p>
      </div>

      <!-- Links -->
      <div>
        <p class="text-cream/40 text-xs font-body tracking-widest uppercase mb-4">Navegación</p>
        <ul class="space-y-2">
          {['#sobre-mi', '#servicios', '#metodologia', '#contacto'].map((href) => (
            <li>
              <a href={href} class="text-cream/60 hover:text-cream text-sm font-body capitalize transition-colors">
                {href.replace('#', '').replace('-', ' ')}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-cream/40 text-xs font-body tracking-widest uppercase mb-4">Contacto</p>
        <div class="space-y-3 text-sm text-cream/60 font-body">
          <p>📍 Pedro Díaz 2041, Virreyes, Bs.As.</p>
          <p>📍 Pedro Ballester 2458, Garín</p>
          <a
            href="https://wa.me/5491132585949"
            class="flex items-center gap-2 text-green-400 hover:text-green-300 transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.118 1.526 5.845L.057 23.272a.5.5 0 00.6.6l5.516-1.447A11.949 11.949 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.94a9.93 9.93 0 01-5.065-1.381l-.363-.215-3.764.987.999-3.654-.237-.375A9.935 9.935 0 012.06 12C2.06 6.5 6.5 2.06 12 2.06S21.94 6.5 21.94 12 17.5 21.94 12 21.94z"/>
            </svg>
            WhatsApp
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-sage-800/40 pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="text-cream/30 text-xs font-body">
        © {new Date().getFullYear()} Raul Lencinas · Terapias Integrativas · Buenos Aires, Argentina
      </p>
      <p class="text-cream/20 text-xs font-body">Miembro de Rotary Sin Fronteras</p>
    </div>
  </div>
</footer>
