---
// Navbar.astro – sticky transparent → opaque on scroll
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 py-5 px-6 md:px-12"
>
  <nav class="max-w-6xl mx-auto flex items-center justify-between">
    <!-- Logo / Name -->
    <a href="#inicio" class="flex flex-col leading-none group">
      <span
        class="font-display text-2xl font-semibold text-cream tracking-wide group-hover:text-earth-light transition-colors"
        style="font-family: 'Cormorant Garamond', serif;"
      >
        Raul Lencinas
      </span>
      <span
        class="text-xs font-body font-light text-sage-200 tracking-[0.2em] uppercase mt-0.5"
      >
        Terapias Integrativas
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden md:flex items-center gap-8">
      {[
        { href: '#sobre-mi', label: 'Sobre Mí' },
        { href: '#servicios', label: 'Servicios' },
        { href: '#metodologia', label: 'Metodología' },
        { href: '#contacto', label: 'Contacto' },
      ].map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-body text-cream/80 hover:text-cream tracking-widest uppercase transition-colors duration-200 relative after:absolute after:bottom-[-4px] after:left-0 after:w-0 after:h-px after:bg-earth-light after:transition-all hover:after:w-full"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA button -->
    <a
      href="https://wa.me/5491132585949?text=Hola%20Raul%2C%20quiero%20consultar%20sobre%20una%20sesi%C3%B3n"
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 btn-gold text-white text-sm font-body font-semibold px-5 py-2.5 rounded-full tracking-wide"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.118 1.526 5.845L.057 23.272a.5.5 0 00.6.6l5.516-1.447A11.949 11.949 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.94a9.93 9.93 0 01-5.065-1.381l-.363-.215-3.764.987.999-3.654-.237-.375A9.935 9.935 0 012.06 12C2.06 6.5 6.5 2.06 12 2.06S21.94 6.5 21.94 12 17.5 21.94 12 21.94z"/>
      </svg>
      Reservar sesión
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Abrir menú"
    >
      <span class="w-6 h-0.5 bg-cream block transition-all" id="bar1"></span>
      <span class="w-6 h-0.5 bg-cream block transition-all" id="bar2"></span>
      <span class="w-4 h-0.5 bg-cream block transition-all self-end" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute top-full left-0 right-0 bg-forest/95 backdrop-blur-lg border-t border-sage-700/30 px-6 py-6"
  >
    <ul class="flex flex-col gap-5">
      {[
        { href: '#sobre-mi', label: 'Sobre Mí' },
        { href: '#servicios', label: 'Servicios' },
        { href: '#metodologia', label: 'Metodología' },
        { href: '#contacto', label: 'Contacto' },
      ].map(({ href, label }) => (
        <li>
          <a href={href} class="mobile-link block text-cream/80 hover:text-cream text-lg font-body tracking-widest uppercase">
            {label}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://wa.me/5491132585949"
          class="btn-gold inline-block text-white text-sm font-semibold px-6 py-3 rounded-full mt-2"
        >
          Reservar sesión
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 60) {
      navbar?.classList.add('bg-forest/95', 'backdrop-blur-lg', 'shadow-xl', 'py-3');
      navbar?.classList.remove('py-5');
    } else {
      navbar?.classList.remove('bg-forest/95', 'backdrop-blur-lg', 'shadow-xl', 'py-3');
      navbar?.classList.add('py-5');
    }
  });

  // Mobile menu toggle
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close on link click
  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
